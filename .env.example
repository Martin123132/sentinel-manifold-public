# Optional in local development. Required for hosted deployments.
SENTINEL_API_KEY=change-me

# Optional hosted sandbox mode. Public users get bounded demo routes only.
SENTINEL_PUBLIC_DEMO=false

# Server binding. Render supplies PORT automatically.
HOST=127.0.0.1
PORT=8787

# Optional provider adapters.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_HOST=http://127.0.0.1:11434

